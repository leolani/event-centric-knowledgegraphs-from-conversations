    leolaniWorld:8-3-2026 a n2mu:date,
            gaf:Instance ;
        rdfs:label "8-3-2026" ;
        gaf:denotedIn leolaniTalk:chat12_utterance1_char0-15 .

    leolaniWorld:beer a n2mu:drink,
