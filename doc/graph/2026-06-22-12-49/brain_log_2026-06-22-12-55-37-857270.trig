        gaf:denotedIn leolaniTalk:chat12_utterance1_char0-15 .

    leolaniWorld:leolani a n2mu:robot ;
        rdfs:label "leolani" .

    leolaniWorld:piek a n2mu:person,
            gaf:Instance ;
        rdfs:label "piek" .
}

leolaniTalk:Perspectives {
    leolaniTalk:drink-2_hasActor_john-1_311-1-1 a grasp:Attribution ;
        rdfs:label "drink-2_hasActor_john-1_311-1-1" ;
        grasp:isAttributionFor leolaniTalk:chat12_utterance1_char0-15 ;
        rdf:value graspe:UNDERSPECIFIED,
            graspf:CERTAIN,
            graspf:POSITIVE,
            graspl:UNDERSPECIFIED,
            grasps:POSITIVE .

    graspe:UNDERSPECIFIED a grasp:AttributionValue,
            graspe:EmotionValue ;
        rdfs:label "UNDERSPECIFIED" .

    graspf:CERTAIN a grasp:AttributionValue,
            graspf:CertaintyValue ;
        rdfs:label "CERTAIN" .

    graspf:POSITIVE a grasp:AttributionValue,
            graspf:PolarityValue ;
        rdfs:label "POSITIVE" .

    graspl:UNDERSPECIFIED a n2mu:LevelValue,
            grasp:AttributionValue ;
        rdfs:label "UNDERSPECIFIED" .

    grasps:POSITIVE a grasp:AttributionValue,
            grasps:SentimentValue ;
        rdfs:label "POSITIVE" .

    leolaniTalk:chat12_utterance1_char0-15 a gaf:Mention,
            grasp:Statement ;
        rdfs:label "chat12_utterance1_char0-15" ;
        gaf:containsDenotation leolaniWorld:8-3-2026,
            leolaniWorld:beer,
            leolaniWorld:drink-2,
            leolaniWorld:john-1,
            leolaniWorld:pub ;
        gaf:denotes leolaniWorld:drink-2_hasActor_john-1 ;
        grasp:hasAttribution leolaniTalk:drink-2_hasActor_john-1_311-1-1 ;
        grasp:wasAttributedTo leolaniFriends:piek-1 ;
        sem:hasBeginTimeStamp "2021-03-12 12:55:30.223036"^^xml1:string ;
        rdf:value "John drinks beer"^^xml1:string ;
        prov:wasDerivedFrom leolaniTalk:chat12_utterance1 .
}

leolaniWorld:drink-2_hasActor_john-1 {
    leolaniWorld:drink-2 ns1:hasActor leolaniWorld:beer,
