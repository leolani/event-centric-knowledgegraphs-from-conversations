leolaniTalk:Interactions {
    leolaniContext:context37 sem:hasEvent leolaniTalk:chat12 .

    leolaniFriends:piek-1 a n2mu:person,
            gaf:Instance,
            grasp:Source,
            sem:Actor ;
        rdfs:label "piek" .

    leolaniTalk:chat12 a grasp:Chat,
            sem:Event ;
        rdfs:label "chat12" ;
        n2mu:id "12"^^xml1:string ;
        sem:hasSubEvent leolaniTalk:chat12_utterance1 .

    leolaniTalk:chat12_utterance1 a grasp:Utterance,
            sem:Event ;
        rdfs:label "chat12_utterance1" ;
        n2mu:id "1"^^xml1:string ;
        sem:hasActor leolaniFriends:piek-1 .
}

leolaniWorld:leolani_know_piek-1 {
    leolaniWorld:leolani n2mu:know leolaniFriends:piek-1 .
}

leolaniWorld:Claims {
    leolaniWorld:drink-2_hasActor_john-1 a gaf:Assertion,
            sem:Event ;
        rdfs:label "drink-2_hasActor_john-1" ;
        gaf:denotedBy leolaniTalk:chat12_utterance1_char0-15 .

    leolaniWorld:leolani_know_piek-1 a gaf:Assertion,
            sem:Event ;
        rdfs:label "leolani_know_piek-1" .

    leolaniFriends:piek-1 owl:sameAs leolaniWorld:piek .
}

