@prefix eps: <http://cltl.nl/episodicawareness/> .
@prefix leolaniContext: <http://cltl.nl/leolani/context/> .
@prefix leolaniTalk: <http://cltl.nl/leolani/talk/> .
@prefix leolaniWorld: <http://cltl.nl/leolani/world/> .
@prefix n2mu: <http://cltl.nl/leolani/n2mu/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sem: <http://semanticweb.cs.vu.nl/2009/11/sem/> .
@prefix time1: <http://www.w3.org/TR/owl-time/#> .
@prefix xml1: <https://www.w3.org/TR/xmlschema-2/#> .

leolaniTalk:Interactions {
    leolaniContext:context197 a eps:Context ;
        rdfs:label "context197" ;
        n2mu:id "197"^^xml1:string ;
        sem:hasBeginTimeStamp leolaniContext:2013-05-11 ;
        sem:hasPlace leolaniContext:vu-aula .

    leolaniContext:2013-05-11 a sem:Time,
            time1:DateTimeDescription ;
        rdfs:label "2013-05-11" ;
        time1:day "11"^^xml1:gDay ;
        time1:month "5"^^xml1:gMonthDay ;
        time1:unitType time1:unitDay ;
        time1:year "2013"^^xml1:gYear .

    leolaniContext:vu-aula a n2mu:location,
            sem:Place ;
        rdfs:label "vu-aula" ;
        n2mu:id "68"^^xml1:string ;
        n2mu:in leolaniWorld:Amsterdam,
            leolaniWorld:NL,
            leolaniWorld:North_Holland .

    leolaniWorld:Amsterdam a n2mu:city,
            n2mu:location,
            sem:Place ;
        rdfs:label "Amsterdam" .

    leolaniWorld:NL a n2mu:country,
            n2mu:location,
            sem:Place ;
        rdfs:label "NL" .

    leolaniWorld:North_Holland a n2mu:location,
            n2mu:region,
            sem:Place ;
        rdfs:label "North Holland" .
}

