    graspf:UNDERSPECIFIED a grasp:AttributionValue,
            graspf:CertaintyValue ;
        rdfs:label "UNDERSPECIFIED" .

    graspl:SOMEWHAT a n2mu:LevelValue,
            grasp:AttributionValue ;
        rdfs:label "SOMEWHAT" .

    grasps:POSITIVE a grasp:AttributionValue,
            grasps:SentimentValue ;
        rdfs:label "POSITIVE" .

    leolaniTalk:chat1_utterance8_char0-75 a gaf:Mention,
            grasp:Statement ;
        rdfs:label "chat1_utterance8_char0-75" ;
        gaf:containsDenotation n2mu:walking0.2987234562034081,
