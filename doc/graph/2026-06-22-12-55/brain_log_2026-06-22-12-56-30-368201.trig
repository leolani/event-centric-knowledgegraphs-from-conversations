leolaniTalk:Perspectives {
    leolaniTalk:walking0.2987234562034081_agent_Jan_011210 a grasp:Attribution ;
        rdfs:label "walking0.2987234562034081_agent_Jan_011210" ;
        grasp:isAttributionFor leolaniTalk:chat1_utterance8_char0-75 ;
        rdf:value graspe:GRATITUDE,
